<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Redirect HTTP → HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Handle Authorization Header (O2Switch / Apache shared hosting)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect index.php
    RewriteCond %{REQUEST_URI} ^/index\.php$
    RewriteRule ^ / [L,R=301]

    # Serve existing files and directories directly
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Route everything else through Laravel
    RewriteRule ^ index.php [L]
</IfModule>

# ── Cache static assets (O2Switch performance) ────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp          "access plus 1 year"
    ExpiresByType image/jpeg          "access plus 1 year"
    ExpiresByType image/png           "access plus 1 year"
    ExpiresByType image/svg+xml       "access plus 1 year"
    ExpiresByType text/css            "access plus 6 months"
    ExpiresByType application/javascript "access plus 6 months"
    ExpiresByType application/json    "access plus 0 seconds"
</IfModule>

# ── Security headers supplement (SecurityHeaders middleware handles the rest) ──
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    # Remove server signature
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── Block access to sensitive files ───────────────────────────────────────────
<FilesMatch "(\.env|\.env\..*|\.git|composer\.(json|lock)|package(-lock)?\.json|artisan)$">
    Order allow,deny
    Deny from all
</FilesMatch>
