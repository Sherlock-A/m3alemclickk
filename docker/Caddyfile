{
    frankenphp
    admin off
    log {
        level ERROR
    }
}

{$SERVER_NAME} {
    root * /app/public

    # Compress responses
    encode zstd br gzip

    # PHP via FrankenPHP (single threaded — fast for Laravel)
    php_server {
        resolve_root_symlink
    }

    # Strip server fingerprint headers (belt-and-suspenders with php.ini expose_php=Off)
    header {
        -Server
        -X-Powered-By
    }

    # Static files cache
    @static {
        file
        path *.css *.js *.ico *.png *.jpg *.jpeg *.webp *.svg *.woff *.woff2
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    file_server
}
