APP_NAME=Jobly
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://jobly.ma

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_TIMEZONE=Africa/Casablanca
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database (O2Switch : créer la DB dans cPanel → MySQL Databases) ──────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=o2switch_username_jobly
DB_USERNAME=o2switch_username_jobly
DB_PASSWORD=

# ─── Session & Cache ──────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.jobly.ma

BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=jobly

# ─── Mail (Resend.com — gratuit, 3000 emails/mois) ────────────────────────────
# 1. Créer un compte sur resend.com
# 2. Obtenir une API key dans API Keys
# 3. Ajouter jobly.ma comme domaine vérifié dans Resend
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@jobly.ma"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=re_your_api_key_here

# ─── Emails destinataires ─────────────────────────────────────────────────────
ADMIN_EMAIL=your-admin-email@jobly.ma
CONTACT_EMAIL=contact@jobly.ma

# ─── Admin initial (utilisé lors du premier seed) ────────────────────────────
ADMIN_PASSWORD=ChangeMeOnFirstLogin!

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : php artisan jwt:secret
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=43200
JWT_REFRESH_TTL=302400
JWT_BLACKLIST_ENABLED=true

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# 1. console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorized redirect URI : https://jobly.ma/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://jobly.ma/auth/google/callback

# ─── Pusher (temps réel — notifications dashboard pro) ───────────────────────
# 1. Créer un compte sur pusher.com (gratuit : 100 connexions / 200k msg/jour)
# 2. Créer une app Pusher → copier les clés ci-dessous
# 3. Choisir cluster "eu" (Frankfurt) pour le Maroc
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu

# ─── Vite (exposé au navigateur — PAS de secrets ici) ─────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
