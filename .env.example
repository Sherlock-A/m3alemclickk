APP_NAME=M3allemClick
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://m3alemclick.ma

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_TIMEZONE=Africa/Casablanca
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=m3allemclick
DB_USERNAME=root
DB_PASSWORD=

# ─── Session & Cache ──────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=m3allemclick

# ─── Redis (optionnel, pour performances) ─────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@m3alemclick.ma
MAIL_FROM_NAME="${APP_NAME}"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=43200
JWT_REFRESH_TTL=302400
JWT_BLACKLIST_ENABLED=true

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_DEFAULT_MESSAGE=Bonjour, je vous contacte via M3allemClick.
