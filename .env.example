APP_NAME=Jobly
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_TIMEZONE=Africa/Casablanca
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database (Railway fournit automatiquement DATABASE_URL) ──────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ─── Session & Cache ──────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=jobly

# ─── Mail (Resend.com — gratuit, 3000 emails/mois) ────────────────────────────
# 1. Créer un compte sur https://resend.com
# 2. Obtenir une API key dans API Keys
# 3. Mettre MAIL_MAILER=resend et renseigner RESEND_API_KEY
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@jobly.ma"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=re_your_api_key_here

# ─── Emails destinataires ─────────────────────────────────────────────────────
ADMIN_EMAIL=your-admin-email@example.com
CONTACT_EMAIL=contact@m3allemclick.ma

# ─── Admin initial (utilisé lors du premier seed) ────────────────────────────
ADMIN_PASSWORD=ChangeMeOnFirstLogin!

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : php artisan jwt:secret
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=43200
JWT_REFRESH_TTL=302400
JWT_BLACKLIST_ENABLED=true

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# 1. https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorized redirect URI: https://your-app.up.railway.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/auth/google/callback

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
